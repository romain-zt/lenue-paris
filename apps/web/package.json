{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "vercel-build": "echo 'y' | payload migrate && next build",
    "generate:importmap": "payload generate:importmap",
    "start": "echo 'y' | payload migrate && next start -p 3001",
    "migrate": "echo 'y' | payload migrate",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "check:assets": "tsx scripts/check-assets.ts",
    "test:e2e": "playwright test",
    "test:maison-hooks": "playwright test e2e/maison-hooks.spec.ts && vitest run src/components/product/__tests__/OrderCTA.maison.test.tsx",
    "generate:types": "payload generate:types",
    "seed": "tsx --env-file=../../.env src/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/react": "^3.0.210",
    "@payloadcms/db-postgres": "catalog:",
    "@payloadcms/live-preview-react": "catalog:",
    "@payloadcms/next": "catalog:",
    "@payloadcms/richtext-lexical": "catalog:",
    "@payloadcms/storage-s3": "catalog:",
    "@payloadcms/translations": "catalog:",
    "@payloadcms/ui": "catalog:",
    "ai": "^6.0.208",
    "next": "catalog:",
    "next-intl": "^3.26.3",
    "payload": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "dotenv": "^17.4.2",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "jsdom": "catalog:",
    "pg": "^8.20.0",
    "tailwindcss": "catalog:",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
