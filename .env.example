# Copy to .env. Never commit .env.

# --- Postgres (Neon in production, local docker for dev) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URI=postgres://app:app@localhost:5432/app

# --- Payload ---
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- S3 / MinIO (media) ---
# Production: AWS S3. Local dev: MinIO (docker-compose).
S3_BUCKET=lenue-media
S3_REGION=eu-west-3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# MinIO needs path-style addressing (local only — remove for AWS S3)
S3_FORCE_PATH_STYLE=true

# --- MinIO root (docker-compose, local only) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- WhatsApp checkout ---
WHATSAPP_PHONE=+33XXXXXXXXX

# --- URLs ---
CMS_URL=http://localhost:3000
WEB_URL=http://localhost:3001
NEXT_PUBLIC_CMS_URL=http://localhost:3000
