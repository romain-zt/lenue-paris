# Copy to .env. Never commit .env.

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URI=postgres://app:app@localhost:5432/app

# --- Payload ---
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- S3 / MinIO (media) ---
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# MinIO needs path-style addressing
S3_FORCE_PATH_STYLE=true

# --- MinIO root (docker-compose) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- URLs ---
# CMS_URL is no longer required — Payload runs inside apps/web (same process).
# WEB_URL is used for cross-service references if needed.
WEB_URL=http://localhost:3001

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=79117126262

# --- Seed (production) ---
# Set on Vercel, then: curl -H "Authorization: Bearer $SEED_SECRET" https://www.lenue.paris/api/seed
SEED_SECRET=
