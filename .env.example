# Copy to .env. Never commit .env.

# --- Postgres (must match docker-compose.yml — host port 5433) ---
# Windows: native Postgres often uses 5432; Docker is mapped to 5433 to avoid conflicts.
# DATABASE_URL takes priority over DATABASE_URI if both are set — keep them aligned.
POSTGRES_USER=lenueparis
POSTGRES_PASSWORD=lenueparis
POSTGRES_DB=lenueparis
DATABASE_URL=postgres://lenueparis:lenueparis@localhost:5433/lenueparis

# --- Payload ---
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- S3 / MinIO (media) ---
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=lenueparis
S3_SECRET_ACCESS_KEY=lenueparis123
# MinIO needs path-style addressing
S3_FORCE_PATH_STYLE=true

# --- MinIO root (docker-compose) ---
MINIO_ROOT_USER=lenueparis
MINIO_ROOT_PASSWORD=lenueparis123

# --- URLs ---
# CMS_URL is no longer required — Payload runs inside apps/web (same process).
# WEB_URL is used for cross-service references if needed.
WEB_URL=http://localhost:3001

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=79117126262

# --- Seed (production) ---
# Set on Vercel, then: curl -H "Authorization: Bearer $SEED_SECRET" https://www.lenue.paris/api/seed
SEED_SECRET=

# --- Editor share link (storefront live edit + AI chat for guests) ---
# Generate once: openssl rand -hex 24
EDITOR_SHARE_TOKEN=

# --- AI assistant ---
OPENAI_API_KEY=
AI_MODEL_CONTENU=gpt-4o-mini
AI_MODEL_DEV=gpt-4o
# Embedding model for semantic search (content_chunks table, requires pgvector)
AI_EMBEDDING_MODEL=text-embedding-3-small
# Set to 1 to run reindex-all after migrate locally (Vercel/CI always attempt when OPENAI_API_KEY is set)
AI_AUTO_REINDEX=0
