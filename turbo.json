{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalPassThroughEnv": [
    "PAYLOAD_SECRET",
    "DATABASE_URI",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "POSTGRES_URL",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_DATABASE",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_HOST",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGDATABASE",
    "PGUSER",
    "PGPASSWORD",
    "NEON_AUTH_BASE_URL",
    "NEON_PROJECT_ID",
    "VITE_NEON_AUTH_URL",
    "S3_BUCKET",
    "S3_REGION",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_FORCE_PATH_STYLE",
    "NEXT_PUBLIC_WHATSAPP_NUMBER",
    "SEED_SECRET",
    "OPENAI_API_KEY",
    "AI_EMBEDDING_MODEL",
    "AI_MODEL_CONTENU",
    "AI_MODEL_DEV"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
