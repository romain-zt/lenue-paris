{
  "name": "lenue-paris",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "next": "catalog:"
  },
  "scripts": {
    "seed": "pnpm --filter web seed",
    "setup": "docker compose up -d && pnpm --filter web migrate && pnpm --filter web seed",
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build --filter=web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
